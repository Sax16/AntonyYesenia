---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Couple from '../components/Couple.astro';
import Countdown from '../components/Countdown.astro';
import Venue from '../components/Venue.astro';
import Story from '../components/Story.astro';
import Gallery from '../components/Gallery.astro';
import Gift from '../components/Gift.astro';
import Message from '../components/Message.astro';
import Footer from '../components/Footer.astro';
import FloatingMenu from '../components/FloatingMenu.astro';
---

<Layout
  title="Antony & Yésenia · Nuestra Boda"
  description="Acompáñanos a celebrar nuestro día más especial — 15 de Agosto de 2026."
>
  <main class="invite-shell">
    <Hero />
    <Couple />
    <Countdown />
    <Venue />
    <Story />
    <Gallery />
    <Message />
    <Footer />
  </main>

  <FloatingMenu />
</Layout>
