---
import { wedding } from '../data/wedding.ts';
import Divider from './Divider.astro';
---

<section class="section" id="novios" style="box-shadow: 0 -80px 120px -80px rgba(155, 31, 51, 0.18); margin-top: -2px;">
  <p class="section-eyebrow">Conoce a la pareja feliz</p>
  <h2 class="section-title">Los Novios</h2>
  <Divider />

  <div class="couple-grid">
    <article class="couple-card">
      <div class="couple-photo">
        <img src={wedding.couple.groom.photo} alt={wedding.couple.groom.name} loading="lazy" />
      </div>
      <h3 class="couple-name">{wedding.couple.groom.name}</h3>
      <p class="couple-role">El Novio</p>
      <p class="couple-parents">
        Hijo de<br />
        {wedding.parents.groom.join(' & ')}
      </p>
    </article>

    <div class="couple-amp" aria-hidden="true">&amp;</div>

    <article class="couple-card">
      <div class="couple-photo">
        <img src={wedding.couple.bride.photo} alt={wedding.couple.bride.name} loading="lazy" />
      </div>
      <h3 class="couple-name">{wedding.couple.bride.name}</h3>
      <p class="couple-role">La Novia</p>
      <p class="couple-parents">
        Hija de<br />
        {wedding.parents.bride.join(' & ')}
      </p>
    </article>
  </div>

  <p class="couple-quote">
    "Hoy unimos nuestras vidas y queremos compartir contigo este momento tan especial."
  </p>
</section>

<style>
  .couple-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    align-items: center;
    margin-top: 1rem;
  }

  .couple-card {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: 1.25rem 1rem 1.5rem;
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-line);
    transition: transform 0.25s ease;
  }

  .couple-card:hover {
    transform: translateY(-3px);
  }

  .couple-photo {
    width: 130px;
    height: 130px;
    margin: 0 auto 0.75rem;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--color-primary-soft);
    background: linear-gradient(135deg, var(--color-primary-soft), var(--color-accent-soft));
  }

  .couple-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .couple-name {
    font-family: var(--font-script);
    color: var(--color-primary);
    font-size: 1.7rem;
    margin: 0;
  }

  .couple-role {
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-accent);
    font-size: 0.72rem;
    margin: 0.3rem 0 0.75rem;
  }

  .couple-parents {
    color: var(--color-text-soft);
    font-size: 0.88rem;
    margin: 0;
    line-height: 1.5;
  }

  .couple-amp {
    font-family: var(--font-script);
    font-size: 3rem;
    color: var(--color-primary);
    line-height: 1;
  }

  .couple-quote {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text-soft);
    margin-top: 2rem;
    padding: 0 1rem;
  }

  @media (min-width: 640px) {
    .couple-grid {
      grid-template-columns: 1fr auto 1fr;
      gap: 1.25rem;
      justify-items: center;
    }

    .couple-card {
      min-width: 80%;
    }
  }
</style>
