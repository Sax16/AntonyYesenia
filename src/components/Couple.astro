---
import { wedding } from '../data/wedding.ts';
import Divider from './Divider.astro';

const leafPaths = {
  tl: '<path d="M32 4c-1 9-6 15-14 19-1-1-2-2-2-4C17 11 23 5 32 4z" fill="currentColor"/><path d="M18 23c2-4 6-9 14-19" stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.55"/>',
  br: '<path d="M8 36c1-9 6-15 14-19 1 1 2 2 2 4-1 8-7 14-16 15z" fill="currentColor"/><path d="M22 17c-2 4-6 9-14 19" stroke="currentColor" stroke-width="0.9" fill="none" stroke-linecap="round" opacity="0.55"/>',
};
---

<section class="section" id="novios" style="box-shadow: 0 -80px 120px -80px rgba(155, 31, 51, 0.18); margin-top: -2px;">
  <p class="section-eyebrow">Conoce a la pareja feliz</p>
  <h2 class="section-title">Los Novios</h2>
  <Divider />

  <div class="couple-grid">
    <article class="couple-person">
      <div class="couple-portrait">
        <span class="couple-portrait-ring" aria-hidden="true"></span>
        <img src={wedding.couple.groom.photo} alt={wedding.couple.groom.name} loading="lazy" />
        <svg class="couple-leaf couple-leaf--tl" viewBox="0 0 40 40" aria-hidden="true" set:html={leafPaths.tl}></svg>
        <svg class="couple-leaf couple-leaf--br" viewBox="0 0 40 40" aria-hidden="true" set:html={leafPaths.br}></svg>
      </div>
      <h3 class="couple-name">{wedding.couple.groom.name}</h3>
      <p class="couple-role">Novio</p>
      <div class="couple-flourish" aria-hidden="true">
        <span></span>
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2c1 3 3 4 6 5-3 1-5 2-6 5-1-3-3-4-6-5 3-1 5-2 6-5z" />
        </svg>
        <span></span>
      </div>
    </article>

    <div class="couple-amp" aria-hidden="true">
      <span class="couple-amp-line couple-amp-line--top"></span>
      <span class="couple-amp-glyph">&amp;</span>
      <span class="couple-amp-line couple-amp-line--bottom"></span>
    </div>

    <article class="couple-person">
      <div class="couple-portrait">
        <span class="couple-portrait-ring" aria-hidden="true"></span>
        <img src={wedding.couple.bride.photo} alt={wedding.couple.bride.name} loading="lazy" />
        <svg class="couple-leaf couple-leaf--tr" viewBox="0 0 40 40" aria-hidden="true" set:html={leafPaths.br}></svg>
        <svg class="couple-leaf couple-leaf--bl" viewBox="0 0 40 40" aria-hidden="true" set:html={leafPaths.tl}></svg>
      </div>
      <h3 class="couple-name">{wedding.couple.bride.name}</h3>
      <p class="couple-role">Novia</p>
      <div class="couple-flourish" aria-hidden="true">
        <span></span>
        <svg viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2c1 3 3 4 6 5-3 1-5 2-6 5-1-3-3-4-6-5 3-1 5-2 6-5z" />
        </svg>
        <span></span>
      </div>
    </article>
  </div>

  <p class="couple-quote">
    Hay momentos en la vida que son especiales por si solos, pero compartirlos con las personas que quieres, los convierte en momentos inolvidables.
  </p>
</section>

<style>
  .couple-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
    justify-items: center;
    margin-top: 1.5rem;
  }

  .couple-person {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    position: relative;
  }

  .couple-portrait {
    position: relative;
    width: 160px;
    height: 160px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary-soft), var(--color-accent-soft));
    padding: 5px;
    box-shadow:
      0 0 0 1px rgba(200, 50, 74, 0.08),
      0 12px 32px -16px rgba(155, 31, 51, 0.4);
  }

  .couple-portrait-ring {
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    border: 1px dashed var(--color-primary-soft);
    opacity: 0.6;
    pointer-events: none;
  }

  .couple-portrait img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 1;
  }

  .couple-leaf {
    position: absolute;
    width: 44px;
    height: 44px;
    color: var(--color-leaf);
    z-index: 2;
    filter: drop-shadow(0 2px 3px rgba(106, 138, 90, 0.25));
  }

  .couple-leaf--tl { top: -8px; left: -8px; transform: rotate(-15deg); }
  .couple-leaf--tr { top: -8px; right: -8px; transform: rotate(15deg) scaleX(-1); }
  .couple-leaf--bl { bottom: -8px; left: -8px; transform: rotate(-15deg) scaleY(-1); }
  .couple-leaf--br { bottom: -8px; right: -8px; transform: rotate(15deg); }

  .couple-name {
    font-family: var(--font-script);
    color: var(--color-primary);
    font-size: 1.9rem;
    margin: 1.1rem 0 0.35rem;
  }

  .couple-role {
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-accent);
    font-size: 0.72rem;
    margin: 0;
  }

  .couple-flourish {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.85rem;
    color: var(--color-primary);
    max-width: 180px;
    width: 100%;
  }

  .couple-flourish span {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary-soft), transparent);
  }

  .couple-flourish svg {
    width: 14px;
    height: 14px;
    opacity: 0.75;
    flex-shrink: 0;
  }

  .couple-amp {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    color: var(--color-primary);
  }

  .couple-amp-glyph {
    font-family: var(--font-script);
    font-size: 3.2rem;
    line-height: 1;
  }

  .couple-amp-line {
    width: 1px;
    height: 28px;
    background: linear-gradient(180deg, transparent, var(--color-primary-soft), transparent);
  }

  .couple-quote {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text-soft);
    margin: 2.5rem auto 0;
    padding: 0 1rem;
    max-width: 560px;
    text-align: center;
    line-height: 1.6;
  }

  @media (min-width: 640px) {
    .couple-grid {
      grid-template-columns: 1fr auto 1fr;
      gap: 1.25rem 2.5rem;
    }

    .couple-amp-line--top,
    .couple-amp-line--bottom {
      display: none;
    }

    .couple-amp {
      position: relative;
    }

    .couple-amp::before,
    .couple-amp::after {
      content: '';
      position: absolute;
      top: 50%;
      width: 32px;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-primary-soft), transparent);
    }

    .couple-amp::before {
      right: 100%;
      margin-right: 0.5rem;
    }

    .couple-amp::after {
      left: 100%;
      margin-left: 0.5rem;
    }
  }
</style>
