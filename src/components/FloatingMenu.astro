---
import { wedding } from '../data/wedding.ts';

const icons: Record<string, string> = {
  couple: '<svg viewBox="0 0 24 24" fill="currentColor"><circle cx="8" cy="7" r="3"/><circle cx="16" cy="7" r="3"/><path d="M2 21c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M10 21c0-3.3 2.7-6 6-6s6 2.7 6 6"/></svg>',
  calendar: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M3 10h18M8 3v4M16 3v4"/><circle cx="8" cy="14" r="1" fill="currentColor"/><circle cx="12" cy="14" r="1" fill="currentColor"/><circle cx="16" cy="14" r="1" fill="currentColor"/></svg>',
  rings: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="9" cy="15" r="5"/><circle cx="16" cy="15" r="5"/><path d="M7 4l2 4M17 4l-2 4M12 2l1 6" stroke-linecap="round"/></svg>',
  cheers: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M5 3l2 8c0 2 1.5 3.5 3 3.8V20H7v2h10v-2h-3v-5.2c1.5-.3 3-1.8 3-3.8l2-8H5zm2.5 2h9l-.7 3h-7.6L7.5 5z"/></svg>',
  book: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h7v16H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1zm9 0h7a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-7V4z"/></svg>',
  gallery: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><circle cx="9" cy="11" r="1.6" fill="currentColor" stroke="none"/><path d="M21 17l-5-5-7 7"/></svg>',
  chat: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M4 4h12a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H10l-5 4v-4H4a3 3 0 0 1-3-3V7a3 3 0 0 1 3-3z" transform="translate(1 0)"/></svg>',
  gift: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20 8h-3.2a3 3 0 0 0-4.8-3.5A3 3 0 0 0 7.2 8H4a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1v7a1 1 0 0 0 1 1h6v-9H5V9h6V8a1 1 0 1 1 2 0v1h6v2h-6v9h6a1 1 0 0 0 1-1v-7a1 1 0 0 0 1-1V9a1 1 0 0 0-1-1z"/></svg>',
  music: '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M9 17V6l11-2v11" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><circle cx="6" cy="17" r="3"/><circle cx="17" cy="15" r="3"/></svg>',
};

const items = [
  { id: 'novios', label: 'Novios', icon: 'couple' },
  { id: 'fecha', label: 'Fecha Boda', icon: 'calendar' },
  { id: 'ceremonia', label: 'Ceremonia', icon: 'rings' },
  { id: 'recepcion', label: 'Recepción', icon: 'cheers' },
  { id: 'historia', label: 'Nuestra Historia', icon: 'book' },
  { id: 'galeria', label: 'Galería', icon: 'gallery' },
  { id: 'mensaje', label: 'Escríbenos !', icon: 'chat' },
];
---

<div class="fm" data-floating-menu>
  <button
    type="button"
    class="fm-fab"
    aria-label="Abrir menú de la invitación"
    aria-expanded="false"
    aria-controls="fm-panel"
    data-fm-toggle
  >
    <span class="fm-fab-ring" aria-hidden="true"></span>
    <svg class="fm-fab-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M4 7h16M4 12h16M4 17h16" />
    </svg>
    <svg class="fm-fab-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <path d="M6 6l12 12M6 18L18 6" />
    </svg>
  </button>

  <div class="fm-backdrop" data-fm-backdrop aria-hidden="true"></div>

  <aside id="fm-panel" class="fm-panel" aria-hidden="true" role="dialog" aria-label="Menú de la invitación">
    <div class="fm-divider" aria-hidden="true">
      <span></span>
      <svg viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2c1 3 3 4 6 5-3 1-5 2-6 5-1-3-3-4-6-5 3-1 5-2 6-5z" />
      </svg>
      <span></span>
    </div>

    <ul class="fm-list">
      <li class="fm-item fm-music">
        <span class="fm-icon" aria-hidden="true" set:html={icons.music}></span>
        <span class="fm-label">Música</span>
        <button
          type="button"
          class="fm-switch"
          role="switch"
          aria-checked="false"
          aria-label="Activar o desactivar música"
          data-music-toggle
        >
          <span class="fm-switch-thumb"></span>
        </button>
        <audio data-music-audio src={wedding.music} loop preload="none"></audio>
      </li>

      {items.map((item) => (
        <li class="fm-item">
          <a href={`#${item.id}`} data-fm-link>
            <span class="fm-icon" aria-hidden="true" set:html={icons[item.icon]}></span>
            <span class="fm-label">{item.label}</span>
          </a>
        </li>
      ))}
    </ul>
  </aside>
</div>

<script>
  function smoothScrollTo(target: string, duration = 700) {
    const el = document.querySelector(target);
    if (!el) return;
    const start = window.scrollY;
    const end = el.getBoundingClientRect().top + start;
    const easeOutQuart = (t: number) => 1 - Math.pow(1 - t, 4);
    const startTime = performance.now();

    function step(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      window.scrollTo(0, start + (end - start) * easeOutQuart(progress));
      if (progress < 1) requestAnimationFrame(step);
    }
    requestAnimationFrame(step);
  }

  document.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('[data-fm-link]');
    if (!link) return;
    const href = link.getAttribute('href');
    if (!href?.startsWith('#')) return;
    e.preventDefault();
    const panel = document.querySelector('[data-floating-menu]');
    if (panel?.classList.contains('is-open')) {
      panel.classList.remove('is-open');
      const toggle = panel.querySelector('[data-fm-toggle]') as HTMLButtonElement;
      const fmPanel = panel.querySelector('.fm-panel') as HTMLElement;
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
      if (fmPanel) fmPanel.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
    setTimeout(() => smoothScrollTo(href), 60);
  });

  const root = document.querySelector('[data-floating-menu]');
  if (root) {
    const toggle = root.querySelector('[data-fm-toggle]') as HTMLButtonElement;
    const panel = root.querySelector('.fm-panel') as HTMLElement;
    const backdrop = root.querySelector('[data-fm-backdrop]') as HTMLElement;
    const links = root.querySelectorAll('[data-fm-link]');

    const setOpen = (open: boolean) => {
      root.classList.toggle('is-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      panel.setAttribute('aria-hidden', String(!open));
      document.body.style.overflow = open ? 'hidden' : '';
    };

    toggle.addEventListener('click', () => {
      setOpen(!root.classList.contains('is-open'));
    });
    backdrop.addEventListener('click', () => setOpen(false));
    links.forEach((l) => l.addEventListener('click', () => setOpen(false)));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });

    const musicBtn = root.querySelector('[data-music-toggle]') as HTMLButtonElement | null;
    const audio = root.querySelector('[data-music-audio]') as HTMLAudioElement | null;
    if (musicBtn && audio) {
      musicBtn.addEventListener('click', async () => {
        const playing = !audio.paused;
        if (playing) {
          audio.pause();
          musicBtn.setAttribute('aria-checked', 'false');
        } else {
          try {
            await audio.play();
            musicBtn.setAttribute('aria-checked', 'true');
          } catch {
            musicBtn.setAttribute('aria-checked', 'false');
          }
        }
      });
    }
  }
</script>

<style>
  .fm {
    position: fixed;
    z-index: 60;
    right: max(1rem, env(safe-area-inset-right));
    bottom: max(1rem, env(safe-area-inset-bottom));
    font-family: var(--font-sans);
  }

  .fm-fab {
    position: relative;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    color: #fff;
    display: grid;
    place-items: center;
    box-shadow: 0 18px 35px -10px rgba(155, 31, 51, 0.55), 0 0 0 6px rgba(200, 50, 74, 0.12);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    z-index: 2;
  }

  .fm-fab:hover {
    transform: translateY(-3px) rotate(-4deg);
  }

  .fm-fab-ring {
    position: absolute;
    inset: -8px;
    border-radius: 50%;
    border: 1.5px dashed rgba(255, 255, 255, 0.4);
    animation: fmSpin 14s linear infinite;
    pointer-events: none;
  }

  .fm-fab svg {
    width: 26px;
    height: 26px;
    transition: opacity 0.2s ease, transform 0.25s ease;
  }

  .fm-fab-close {
    position: absolute;
    opacity: 0;
    transform: rotate(-45deg);
  }

  .fm.is-open .fm-fab-open {
    opacity: 0;
    transform: rotate(45deg);
  }

  .fm.is-open .fm-fab-close {
    opacity: 1;
    transform: rotate(0);
  }

  .fm-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(43, 26, 23, 0.45);
    backdrop-filter: blur(2px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
    z-index: 1;
  }

  .fm.is-open .fm-backdrop {
    opacity: 1;
    pointer-events: auto;
  }

  .fm-panel {
    position: fixed;
    right: 1rem;
    bottom: calc(60px + 1.75rem + env(safe-area-inset-bottom, 0px));
    width: min(320px, calc(100vw - 2rem));
    max-height: min(72vh, 640px);
    overflow-y: auto;
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: 0 30px 70px -25px rgba(155, 31, 51, 0.45);
    padding: 1.5rem 1.25rem 1.25rem;
    transform: translateY(20px) scale(0.96);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.28s cubic-bezier(0.22, 1, 0.36, 1), opacity 0.22s ease;
    z-index: 2;
    border: 1px solid var(--color-line);
  }

  .fm.is-open .fm-panel {
    transform: translateY(0) scale(1);
    opacity: 1;
    pointer-events: auto;
  }

  .fm-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .fm-divider span {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary-soft), transparent);
  }

  .fm-divider svg {
    width: 22px;
    height: 22px;
  }

  .fm-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .fm-item a,
  .fm-item.fm-music {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.65rem 0.5rem;
    border-radius: 12px;
    color: var(--color-primary-dark);
    font-weight: 500;
    font-size: 0.98rem;
    transition: background 0.18s ease, transform 0.18s ease;
  }

  .fm-item a:hover {
    background: var(--color-surface-2);
    transform: translateX(2px);
  }

  .fm-icon {
    display: inline-grid;
    place-items: center;
    width: 26px;
    height: 26px;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .fm-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .fm-label {
    flex: 1;
  }

  .fm-switch {
    width: 40px;
    height: 22px;
    border-radius: 999px;
    background: var(--color-primary-soft);
    position: relative;
    transition: background 0.2s ease;
    flex-shrink: 0;
  }

  .fm-switch-thumb {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 18px;
    height: 18px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
    transition: transform 0.22s ease;
  }

  .fm-switch[aria-checked='true'] {
    background: var(--color-primary);
  }

  .fm-switch[aria-checked='true'] .fm-switch-thumb {
    transform: translateX(18px);
  }

  @keyframes fmSpin {
    to { transform: rotate(360deg); }
  }

  @media (min-width: 720px) {
    .fm {
      right: 2rem;
      bottom: 2rem;
    }
    .fm-panel {
      right: 2rem;
      bottom: calc(60px + 2.75rem);
    }
  }
</style>
