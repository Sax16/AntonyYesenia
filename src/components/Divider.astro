---
interface Props {
  small?: boolean;
}
const { small = false } = Astro.props;
---

<div class="divider" aria-hidden="true" style={small ? '--w:60px' : '--w:90px'}>
  <svg viewBox="0 0 24 24" fill="currentColor">
    <path d="M12 2c1 3 3 4 6 5-3 1-5 2-6 5-1-3-3-4-6-5 3-1 5-2 6-5z" />
    <circle cx="12" cy="18" r="2" />
  </svg>
</div>

<style>
  .divider::before,
  .divider::after {
    max-width: var(--w, 90px);
  }
</style>
