---
import { wedding } from '../data/wedding.ts';

// @ts-ignore: no type declarations for the side-effect font import
import '@fontsource/allura';
---

<header class="hero" id="inicio">
  <div class="hero-layer">
    <div class="hero-bg" style={`background-image:url(${wedding.hero.image})`}></div>
  </div>
  <div class="hero-overlay"></div>

  <div class="hero-content">
    <p class="hero-invite">Nos casamos</p>
    <div class="hero-flourish" aria-hidden="true">
      <span></span>
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c1 3 3 4 6 5-3 1-5 2-6 5-1-3-3-4-6-5 3-1 5-2 6-5z"/></svg>
      <span></span>
    </div>
    <h1 class="hero-names">
      <span class="hero-name">{wedding.couple.groom.name.split(' ')[0]}</span>
      <span class="hero-amp">&amp;</span>
      <span class="hero-name">{wedding.couple.bride.name.split(' ')[0]}</span>
    </h1>
    <div class="hero-line" aria-hidden="true"></div>
    <p class="hero-quote">{wedding.hero.quote}</p>
  </div>

  <button
    type="button"
    class="hero-play"
    data-music-button
    aria-label="Reproducir música"
    aria-pressed="false"
  >
    <span class="hero-play-pulse" aria-hidden="true"></span>
    <span class="hero-play-disc" aria-hidden="true">
      <svg class="hero-play-icon hero-play-icon--play" viewBox="0 0 24 24" fill="currentColor">
        <path d="M8 5v14l11-7L8 5z"/>
      </svg>
      <svg class="hero-play-icon hero-play-icon--pause" viewBox="0 0 24 24" fill="currentColor">
        <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
      </svg>
    </span>
    <span class="hero-play-label">Nuestra canción favorita</span>
  </button>
</header>

<script>
  import { music } from '../lib/music';

  const playButton = document.querySelector<HTMLButtonElement>('[data-music-button]');
  if (playButton) {
    playButton.addEventListener('click', () => music.toggle());
    music.subscribe((playing) => {
      playButton.setAttribute('aria-pressed', String(playing));
      playButton.setAttribute(
        'aria-label',
        playing ? 'Pausar música' : 'Reproducir música'
      );
    });
  }
</script>

<style>
  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100svh;
    display: grid;
    place-items: center;
    color: #fff;
    overflow: hidden;
    isolation: isolate;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center top;
    z-index: -2;
    transform: scale(1.5);
    animation: heroZoom 14s ease-out forwards;
  }

  .hero-layer {
    position: absolute;
    inset: 0;
    background: linear-gradient(rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.2));
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg,
        rgba(43, 26, 23, 0.18) 0%,
        rgba(43, 26, 23, 0.05) 28%,
        rgba(43, 26, 23, 0.08) 50%,
        rgba(43, 26, 23, 0.4) 72%,
        rgba(43, 26, 23, 0.65) 88%,
        rgba(43, 26, 23, 0.82) 100%);
    z-index: -1;
  }

  .hero-content {
    text-align: center;
    padding: 1.5rem 1.5rem 8.5rem;
    max-width: 760px;
    align-self: end;
    animation: heroFade 1.2s ease-out 0.2s both;
  }

  @media (min-width: 720px) {
    .hero-content {
      padding: 1.5rem 1.5rem 6.5rem;
    }
  }

  .hero-invite {
    font-family: var(--font-script);
    font-size: clamp(1.8rem, 3.4vw, 2.5rem);
    color: #ffe6c2;
    margin: 0 0 0.4rem;
  }

  .hero-flourish {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: rgba(255, 230, 194, 0.9);
    margin: 0.35rem auto 0.85rem;
    max-width: 360px;
  }

  .hero-flourish span {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255, 230, 194, 0.65), transparent);
  }

  .hero-flourish svg {
    width: 20px;
    height: 20px;
  }

  .hero-names {
    font-family: Allura, cursive;
    font-weight: 500;
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    line-height: 1.05;
    margin: 0.15rem 0;
    color: #fff;
    text-shadow: 0 6px 28px rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: clamp(0.6rem, 2vw, 1.2rem);
    flex-wrap: wrap;
  }

  .hero-amp {
    color: var(--color-accent);
    font-style: italic;
    font-family: var(--font-script);
    font-size: 0.9em;
    line-height: 1;
  }

  .hero-line {
    width: clamp(70px, 10vw, 110px);
    height: 1px;
    margin: 0.85rem auto;
    background: linear-gradient(90deg, transparent, var(--color-accent), transparent);
  }

  .hero-quote {
    font-family: var(--font-script);
    color: #ffd9c0;
    font-size: clamp(1.1rem, 2.2vw, 1.5rem);
    margin: 0;
  }

.hero-play {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.5rem 1.4rem 0.5rem 0.5rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(0.82rem, 2.3vw, 0.98rem);
    letter-spacing: 0.3px;
    white-space: nowrap;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
    animation: heroPlayFade 1.2s ease-out 0.6s both;
    transition: background 0.2s ease, box-shadow 0.2s ease;
    z-index: 3;
  }

  .hero-play:hover {
    background: rgba(255, 255, 255, 0.22);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.3);
  }

  .hero-play:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 3px;
  }

  .hero-play-pulse {
    position: absolute;
    inset: -6px;
    border-radius: 999px;
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    pointer-events: none;
    opacity: 0;
    animation: heroPlayPulse 2.4s ease-out infinite;
  }

  .hero-play[aria-pressed='false'] .hero-play-pulse {
    opacity: 1;
  }

  @keyframes heroPlayPulse {
    0% { transform: scale(0.96); opacity: 0.7; }
    100% { transform: scale(1.2); opacity: 0; }
  }

  .hero-play-disc {
    position: relative;
    width: 36px;
    height: 36px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
    box-shadow: 0 4px 10px rgba(155, 31, 51, 0.5);
    flex-shrink: 0;
  }

  .hero-play-icon {
    position: absolute;
    width: 14px;
    height: 14px;
    fill: #fff;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .hero-play-icon--play { opacity: 1; transform: scale(1); }
  .hero-play-icon--pause { opacity: 0; transform: scale(0.6); }

  .hero-play[aria-pressed='true'] .hero-play-icon--play { opacity: 0; transform: scale(0.6); }
  .hero-play[aria-pressed='true'] .hero-play-icon--pause { opacity: 1; transform: scale(1); }

  @keyframes heroZoom {
    to { transform: scale(1); }
  }

  @keyframes heroFade {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroPlayFade {
    from { opacity: 0; transform: translateX(-50%) translateY(15px); }
    to { opacity: 1; transform: translateX(-50%) translateY(0); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-play-pulse {
      animation: none;
    }
  }
</style>
