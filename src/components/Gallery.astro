---
import { wedding } from '../data/wedding.ts';
import Divider from './Divider.astro';
---

<section class="section" id="galeria">
  <p class="section-eyebrow">Momentos especiales</p>
  <h2 class="section-title">Galería</h2>
  <Divider />

  <div class="gallery">
    {wedding.gallery.map((src, i) => (
      <figure class={`gallery-item gallery-${i + 1}`}>
        <img src={src} alt={`Foto ${i + 1} de la pareja`} loading="lazy" />
      </figure>
    ))}
  </div>
</section>

<style>
  .gallery {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: 80px;
    gap: 0.5rem;
  }

  .gallery-item {
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius-sm);
    background: var(--color-primary-soft);
    box-shadow: var(--shadow-sm);
    transition: transform 0.25s ease;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .gallery-item:hover {
    transform: scale(1.02);
  }

  .gallery-item:hover img {
    transform: scale(1.08);
  }

  .gallery-1 { grid-column: span 4; grid-row: span 2; }
  .gallery-2 { grid-column: span 2; grid-row: span 2; }
  .gallery-3 { grid-column: span 2; grid-row: span 2; }
  .gallery-4 { grid-column: span 2; grid-row: span 2; }
  .gallery-5 { grid-column: span 2; grid-row: span 2; }
  .gallery-6 { grid-column: span 6; grid-row: span 2; }

  @media (min-width: 640px) {
    .gallery {
      grid-auto-rows: 110px;
    }
  }
</style>
