---
import { wedding } from '../data/wedding.ts';
import Divider from './Divider.astro';

const groom = wedding.couple.groom;
const bride = wedding.couple.bride;
---

<section class="section" id="historia">
  <p class="section-eyebrow">Cómo empezó todo</p>
  <h2 class="section-title">Nuestra Historia</h2>
  <Divider />

  <div class="story-intro">
    <span class="story-intro-line"></span>
    <p class="story-intro-text">
      Dos versiones de un mismo amor
    </p>
    <span class="story-intro-line"></span>
  </div>

  <div class="story-grid">
    <article class="story-note">
      <span class="story-tag">Su versión · Él</span>

      <div class="story-portrait">
        <span class="story-portrait-ring" aria-hidden="true"></span>
        <img src={groom.photo} alt={groom.name} loading="lazy" />
        <svg class="story-portrait-leaf" viewBox="0 0 32 32" aria-hidden="true">
          <path
            d="M28 4c-2 9-7 14-15 17-1-1-2-3-2-5C13 9 19 5 28 4z"
            fill="var(--color-leaf)"
            opacity="0.85"
          />
          <path
            d="M13 21c2-4 6-8 13-15"
            stroke="var(--color-leaf)"
            stroke-width="1.2"
            fill="none"
            stroke-linecap="round"
            opacity="0.6"
          />
        </svg>
      </div>

      <h3 class="story-name">{groom.name}</h3>

      <blockquote class="story-quote">
        <svg class="story-quote-mark" viewBox="0 0 32 32" aria-hidden="true">
          <path
            d="M11 6C6 6 2 9 2 14c0 5 4 9 9 9 1.5 0 2.5-1 2.5-2.5S12.5 18 11 18c-2.5 0-4-1.5-4-4s1.5-4 4-4c1.5 0 2.5-1 2.5-2.5S12.5 6 11 6zm15 0c-5 0-9 3-9 8 0 5 4 9 9 9 1.5 0 2.5-1 2.5-2.5S27.5 18 26 18c-2.5 0-4-1.5-4-4s1.5-4 4-4c1.5 0 2.5-1 2.5-2.5S27.5 6 26 6z"
            fill="currentColor"
          />
        </svg>
        <p>{groom.story}</p>
        <footer>
          <span class="story-signature">Con cariño,</span>
          <span class="story-signature-name">{groom.name.split(' ')[0]}</span>
        </footer>
      </blockquote>
    </article>

    <div class="story-link" aria-hidden="true">
      <span class="story-link-line"></span>
      <svg viewBox="0 0 32 32" fill="currentColor">
        <path d="M16 28s-10-6.5-13-13C1 11 4 6 8.5 6c2.5 0 4.5 1.5 7.5 4 3-2.5 5-4 7.5-4C28 6 31 11 29 15c-3 6.5-13 13-13 13z" />
      </svg>
      <span class="story-link-line"></span>
    </div>

    <article class="story-note">
      <span class="story-tag">Su versión · Ella</span>

      <div class="story-portrait">
        <span class="story-portrait-ring" aria-hidden="true"></span>
        <img src={bride.photo} alt={bride.name} loading="lazy" />
        <svg class="story-portrait-leaf" viewBox="0 0 32 32" aria-hidden="true">
          <path
            d="M28 4c-2 9-7 14-15 17-1-1-2-3-2-5C13 9 19 5 28 4z"
            fill="var(--color-leaf)"
            opacity="0.85"
          />
          <path
            d="M13 21c2-4 6-8 13-15"
            stroke="var(--color-leaf)"
            stroke-width="1.2"
            fill="none"
            stroke-linecap="round"
            opacity="0.6"
          />
        </svg>
      </div>

      <h3 class="story-name">{bride.name}</h3>

      <blockquote class="story-quote">
        <svg class="story-quote-mark" viewBox="0 0 32 32" aria-hidden="true">
          <path
            d="M11 6C6 6 2 9 2 14c0 5 4 9 9 9 1.5 0 2.5-1 2.5-2.5S12.5 18 11 18c-2.5 0-4-1.5-4-4s1.5-4 4-4c1.5 0 2.5-1 2.5-2.5S12.5 6 11 6zm15 0c-5 0-9 3-9 8 0 5 4 9 9 9 1.5 0 2.5-1 2.5-2.5S27.5 18 26 18c-2.5 0-4-1.5-4-4s1.5-4 4-4c1.5 0 2.5-1 2.5-2.5S27.5 6 26 6z"
            fill="currentColor"
          />
        </svg>
        <p>{bride.story}</p>
        <footer>
          <span class="story-signature">Con cariño,</span>
          <span class="story-signature-name">{bride.name.split(' ')[0]}</span>
        </footer>
      </blockquote>
    </article>
  </div>
</section>

<style>
  .story-intro {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.85rem;
    max-width: 460px;
    margin: 0 auto 2rem;
    color: var(--color-text-soft);
  }

  .story-intro-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary-soft), transparent);
  }

  .story-intro-text {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    text-align: center;
    line-height: 1.5;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: start;
    max-width: 960px;
    margin: 0 auto;
  }

  .story-note {
    position: relative;
    padding: 1.75rem 1.5rem 1.5rem;
    background:
      radial-gradient(circle at 50% 0%, rgba(244, 201, 201, 0.35), transparent 60%),
      var(--color-surface);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    text-align: center;
  }

  .story-note::before,
  .story-note::after {
    content: '';
    position: absolute;
    width: 28px;
    height: 8px;
    top: 14px;
    border-radius: 2px;
    background: var(--color-accent-soft);
    transform: rotate(-6deg);
    box-shadow: 0 1px 2px rgba(155, 31, 51, 0.08);
  }

  .story-note::before {
    left: 18px;
  }

  .story-note::after {
    right: 18px;
    background: var(--color-primary-soft);
    transform: rotate(6deg);
  }

  .story-tag {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-size: 0.68rem;
    color: var(--color-accent);
    margin-bottom: 0.85rem;
  }

  .story-portrait {
    position: relative;
    width: 130px;
    height: 130px;
    margin: 0 auto 0.85rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-primary-soft), var(--color-accent-soft));
    padding: 4px;
  }

  .story-portrait-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1px dashed var(--color-primary-soft);
    opacity: 0.85;
    animation: story-spin 26s linear infinite;
  }

  @keyframes story-spin {
    to { transform: rotate(360deg); }
  }

  .story-portrait img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    position: relative;
    z-index: 1;
  }

  .story-portrait-leaf {
    position: absolute;
    width: 36px;
    height: 36px;
    right: -8px;
    top: 6px;
    transform: rotate(20deg);
    z-index: 2;
    filter: drop-shadow(0 2px 3px rgba(106, 138, 90, 0.25));
  }

  .story-name {
    font-family: var(--font-script);
    color: var(--color-primary);
    font-size: 1.6rem;
    font-weight: 400;
    margin: 0 0 0.85rem;
  }

  .story-quote {
    position: relative;
    margin: 0;
    padding: 1.25rem 0.75rem 0.5rem;
    text-align: left;
  }

  .story-quote-mark {
    position: absolute;
    top: -6px;
    left: 50%;
    transform: translateX(-50%);
    width: 32px;
    height: 32px;
    color: var(--color-primary-soft);
    opacity: 0.9;
  }

  .story-quote p {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--color-text);
    text-align: center;
  }

  .story-quote footer {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
  }

  .story-signature {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-muted);
  }

  .story-signature-name {
    font-family: var(--font-script);
    font-size: 1.6rem;
    color: var(--color-primary);
    line-height: 1;
  }

  .story-link {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: var(--color-primary);
    padding: 0.5rem 0;
  }

  .story-link-line {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-primary-soft), transparent);
  }

  .story-link svg {
    width: 26px;
    height: 26px;
    filter: drop-shadow(0 2px 4px rgba(155, 31, 51, 0.2));
  }

  @media (min-width: 720px) {
    .story-grid {
      grid-template-columns: 1fr auto 1fr;
      gap: 1.5rem;
      align-items: stretch;
    }

    .story-note {
      padding: 2rem 1.75rem 1.75rem;
    }

    .story-link {
      flex-direction: column;
      gap: 0.85rem;
      padding-top: 4rem;
    }

    .story-link-line {
      width: 1px;
      height: 60px;
      max-width: none;
      background: linear-gradient(180deg, transparent, var(--color-primary-soft), transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .story-portrait-ring {
      animation: none;
    }
  }
</style>